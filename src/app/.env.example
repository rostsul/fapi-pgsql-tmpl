APP_ENV=production
LOG_LEVEL=info
PORT=8000
WORKERS=2

DATABASE_URL=postgresql+asyncpg://appuser:password@127.0.0.1:5432/appdb #  pragma: allowlist secret
REDIS_URL=redis://default:password@127.0.0.1:6379/0 #  pragma: allowlist secret

# OWASP / Security
CORS_ORIGINS=["127.0.0.1", "https://your-domain.com"]
RATE_LIMIT_PER_MINUTE=60
SECRET_KEY=change-me-in-production-use-openssl-rand
